# ---------- MODE GATES ----------
# signals = read-only, log + alert only (DEFAULT)
# paper   = synthetic portfolio in DB, still no real orders
# live    = real Kalshi orders (also requires LIVE_TRADING_CONFIRMED=true)
TRADING_MODE=signals
LIVE_TRADING_CONFIRMED=false

# ---------- KALSHI ----------
# Generate RSA key pair via Kalshi portal: Settings > API Keys > Create
# Save the private key as a multi-line PEM. In .env, escape newlines as \n.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
# demo: https://demo-api.kalshi.co/trade-api/v2

# ---------- ANTHROPIC ----------
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
FORECAST_MODEL=claude-sonnet-4-6

# ---------- DATABASE ----------
DATABASE_URL=

# ---------- TELEGRAM ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- NEWS ----------
# https://newsapi.org — free tier 100 req/day, paid is cheap
NEWSAPI_KEY=

# ---------- THRESHOLDS ----------
EDGE_MIN_CENTS=8
CONFIDENCE_MIN=0.75
MAX_SPREAD_CENTS=20
MIN_HOURS_TO_RESOLUTION=24
MAX_DAYS_TO_RESOLUTION=180
MAX_BET_USD=50
KELLY_FRACTION=0.25

# ---------- SCHEDULER ----------
DISCOVERY_CRON=*/30 * * * *
RESOLVER_CRON=15 9 * * *
DAILY_DIGEST_CRON=0 9 * * *

# ---------- SERVER ----------
PORT=3002
NODE_ENV=development
